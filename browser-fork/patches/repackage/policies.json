    "//ExtensionSettings": "Allowlist: only our shipped extensions can install. anon-layer is unsigned by design (no AMO submission for v0); the matching xpinstall.signatures.required=false in Preferences lets it load, while this allowlist prevents that hole from being abused to install other unsigned addons. The Mullvad-VPN companion is explicitly blocked to stop reinstall via cdn.mullvad.net.",
    "ExtensionSettings": {
      "*": {
        "installation_mode": "blocked"
      },
      "anon-layer@anon.gratis": {
        "installation_mode": "force_installed",
        "install_url": "file://@@INSTALL_DIR@@/Browser/distribution/extensions/anon-layer@anon.gratis.xpi"
      },
      "{73a6fe31-595d-460b-a920-fcc0f8843232}": {
        "installation_mode": "allowed"
      },
      "uBlock0@raymondhill.net": {
        "installation_mode": "allowed"
      },
      "{d19a89b9-76c1-4a61-bcd4-49e8de916403}": {
        "installation_mode": "blocked"
      }
    },
    "OfferToSaveLogins": false,
    "PasswordManagerEnabled": false,
    "SearchSuggestEnabled": false,
    "PromptForDownloadLocation": true,
    "//SearchEngines-disabled": "We tried a custom search engine with alias 'anon' and URLTemplate web+anon://{searchTerms}, but (a) it conflicts with the extension's own omnibox keyword on the same alias (search engine wins, omnibox loses), and (b) the resulting web+anon:// navigation comes from chrome context, which Firefox refuses to dispatch to extension handlers. The omnibox keyword from the extension already does the right thing \u2014 leave it alone.",
    "Preferences": {
      "browser.toolbars.bookmarks.visibility": {
        "Value": "always",
        "Status": "locked",
        "//": "Override the Mullvad 'never' default so the Demo bookmark on the toolbar is actually visible."
      },
      "browser.startup.homepage": {
        "Value": "about:blank",
        "Status": "default"
      },
      "browser.urlbar.suggest.bookmark": {
        "Value": false,
        "Status": "locked"
      },
      "browser.urlbar.suggest.history": {
        "Value": false,
        "Status": "default"
      },
      "browser.urlbar.suggest.openpage": {
        "Value": false,
        "Status": "default"
      },
      "network.proxy.allow_hijacking_localhost": {
        "Value": false,
        "Status": "locked",
        "//": "Ensure 127.0.0.1 requests bypass any user-configured proxy. The extension's bridge fetch depends on this."
      },
      "media.peerconnection.enabled": {
        "Value": false,
        "Status": "locked",
        "//": "Block WebRTC entirely \u2014 even without a proxy, WebRTC fingerprints and can leak the real IP via STUN/ICE."
      },
      "media.navigator.enabled": {
        "Value": false,
        "Status": "locked"
      },
      "xpinstall.signatures.required": {
        "Value": false,
        "Status": "locked",
        "//": "Required so the unsigned anon-layer XPI can load. The ExtensionSettings allowlist above prevents this from being abused to install other unsigned addons. The Mullvad build doesn't bake MOZ_REQUIRE_SIGNING into libxul, so this pref actually takes effect (verified)."
      }
    }
  }
