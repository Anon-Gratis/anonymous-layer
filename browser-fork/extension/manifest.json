{
  "manifest_version": 3,
  "name": "Anon Layer",
  "short_name": "Anon",
  "version": "0.1.0",
  "description": "Native browsing of the anon-layer v0.2 network. Routes anon:// URLs to a local anon-browse-gui bridge and renders text/anon documents in-tab.",
  "homepage_url": "https://github.com/anon-gratis/anonymous-layer",
  "author": "Anonymous Gratis",

  "icons": {
    "48":  "icons/icon-48.png",
    "96":  "icons/icon-96.png",
    "256": "icons/icon-256.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "anon-layer@anon.gratis",
      "strict_min_version": "115.0"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "action": {
    "default_title": "Anon Layer — open browser",
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png"
    },
    "default_popup": "popup.html"
  },

  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking"
  ],

  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "<all_urls>"
  ],

  "omnibox": {
    "keyword": "anon"
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/intercept.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "render.html",
        "render.js",
        "lib/render-doc.mjs",
        "common.css",
        "icons/icon-48.png",
        "icons/icon-96.png",
        "icons/icon-256.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+anon",
      "name": "Anon Layer",
      "uriTemplate": "render.html?u=%s"
    }
  ]
}
