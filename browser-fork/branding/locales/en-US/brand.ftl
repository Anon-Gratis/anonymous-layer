## Anon Browser brand strings
##
## Override of upstream Firefox brand strings. Schema matches
## browser/branding/official/locales/en-US/brand.ftl in mozilla-central
## so the build system finds every expected message.

-brand-shorter-name = Anon
-brand-short-name = Anon Browser
-brand-shortcut-name = Anon Browser
-brand-full-name = Anon Browser
# This brand name can be used in messages where the product name needs to
# remain unchanged across different versions (Nightly, Beta, etc.).
-brand-product-name = Anon Browser
-vendor-short-name = Anonymous Layer
trademarkInfo = Anon Browser and the Anon Browser logos are trademarks of the Anonymous Layer project.
