# Copy to .env in the DA's compose dir and fill in:

# DNS hostname for this DA. Must resolve to the VPS public IP before
# bringing up the stack (ACME challenge will fail otherwise).
DA_DOMAIN=da1.anon.gratis

# Where Let's Encrypt sends cert-expiry notices.
ACME_EMAIL=admin@anon.gratis

# Consensus document lifetime, seconds. Clients re-fetch every hour;
# stale consensus is rejected after this window. Default 3600.
ANON_CONSENSUS_LIFETIME=3600
