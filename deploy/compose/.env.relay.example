# Copy to .env in the relay's compose dir and fill in:

# DNS hostname that resolves to this VPS's public IP. Caddy uses this
# both as the cert SAN and as the only hostname it'll accept on :443.
# Must already resolve (A or AAAA record) before bringing the stack up,
# or ACME challenge will fail.
RELAY_DOMAIN=relay-is1.anon.gratis

# Where Let's Encrypt sends cert-expiry notices.
ACME_EMAIL=admin@anon.gratis

# reject   — middle/guard only (default; safest for new operators)
# reduced  — common ports only (80/443/etc); see modules/v2/exit_policy.mjs
# standard — broad exit policy
ANON_EXIT_POLICY=reject

# Auto-refresh consensus from the DA(s). Empty/unset = manual only
# (operator runs `curl > config/consensus.bin && docker compose
# restart anon-node` after each DA publish). With a value set the
# entrypoint polls every ANON_REFRESH_INTERVAL_SEC and SIGTERMs the
# daemon on detected change — docker's restart-policy relaunches it
# against the new file. Comma-separated list for failover across DAs.
ANON_REFRESH_FROM=https://da1.anon.gratis
ANON_REFRESH_INTERVAL_SEC=1200
